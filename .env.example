# ===================================
# Visual Study Tool - Environment Config
# ===================================
# Copy this file to .env and fill in your API keys.
# All values are optional; free sources work without them.

# ===================================
# Optional API Keys
# ===================================

# Unsplash (https://unsplash.com/oauth/applications)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here

# Pexels (https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=your_pixabay_api_key_here

# OpenVerse (https://api.openverse.engineering/)
OPENVERSE_API_KEY=your_openverse_api_key_here

# ===================================
# Search Engine Configuration
# ===================================

# Enable multi-engine search (combines results from all sources)
ENABLE_MULTI_ENGINE=true

# Individual engine toggles
ENABLE_DDG=true
ENABLE_UNSPLASH=true
ENABLE_PEXELS=true
ENABLE_PIXABAY=true
ENABLE_OPENVERSE=true
ENABLE_WIKIMEDIA=true

# DuckDuckGo quality fallback
ENABLE_DDG_QUALITY_FALLBACK=true
DDG_MATCH_MIN=4

# ===================================
# Performance & Sizing
# ===================================

# Number of results to fetch per search
SEARCH_POOL_SIZE=120

# Images to download per batch
DOWNLOAD_BATCH_SIZE=60

# Images to display per batch
DISPLAY_BATCH_SIZE=60

# Maximum images in gallery (older entries deleted when exceeded)
MAX_GALLERY_ITEMS=180

# Default image resize dimensions
DEFAULT_IMAGE_SIZE=512,512

# ===================================
# Content Bias & Weighting
# ===================================

# Multiplier for featured/prominent images
FEATURE_WEIGHT_MULTIPLIER=1.6

# ===================================
# Scoring & Filtering
# ===================================

# Minimum CLIP similarity threshold for ranking
BASE_SIMILARITY_THRESHOLD=0.18

# Safety margin for integrity checks
INTEGRITY_MARGIN=0.02

# Minimum images to keep even if below threshold
INTEGRITY_MIN_KEEP=12

# Minimum ratio of results to keep
INTEGRITY_MIN_KEEP_RATIO=0.2

# Minimum score for display
MIN_DISPLAY_SCORE=20.0

# Display score multiplier
SCORE_DISPLAY_MULTIPLIER=250

# ===================================
# Timeouts (seconds)
# ===================================

SEARCH_TIMEOUT=8
DOWNLOAD_TIMEOUT=3

# ===================================
# Logging
# ===================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
